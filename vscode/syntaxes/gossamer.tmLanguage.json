{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Gossamer",
  "scopeName": "source.gossamer",
  "fileTypes": ["gos"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#chars" },
    { "include": "#attributes" },
    { "include": "#numbers" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#literals" },
    { "include": "#pipe" },
    { "include": "#operators" },
    { "include": "#functions" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.gossamer",
          "match": "//.*$"
        },
        {
          "name": "comment.block.gossamer",
          "begin": "/\\*",
          "end": "\\*/",
          "patterns": [{ "include": "#comments" }]
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.raw.gossamer",
          "begin": "b?r(#*)\"",
          "end": "\"\\1",
          "patterns": []
        },
        {
          "name": "string.quoted.double.gossamer",
          "begin": "b?\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.gossamer",
              "match": "\\\\([nrt0\\\\\"']|x[0-9A-Fa-f]{2}|u\\{[0-9A-Fa-f]+\\})"
            }
          ]
        }
      ]
    },
    "chars": {
      "patterns": [
        {
          "name": "string.quoted.single.gossamer",
          "match": "b?'(\\\\([nrt0\\\\\"']|x[0-9A-Fa-f]{2}|u\\{[0-9A-Fa-f]+\\})|.)'"
        }
      ]
    },
    "attributes": {
      "patterns": [
        {
          "name": "meta.attribute.gossamer",
          "begin": "#!?\\[",
          "end": "\\]",
          "patterns": [
            { "include": "#strings" },
            { "include": "#identifiers" }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.hex.gossamer",
          "match": "\\b0x[0-9a-fA-F_]+(?:[iuf](?:8|16|32|64|128|size))?\\b"
        },
        {
          "name": "constant.numeric.binary.gossamer",
          "match": "\\b0b[01_]+(?:[iuf](?:8|16|32|64|128|size))?\\b"
        },
        {
          "name": "constant.numeric.octal.gossamer",
          "match": "\\b0o[0-7_]+(?:[iuf](?:8|16|32|64|128|size))?\\b"
        },
        {
          "name": "constant.numeric.decimal.gossamer",
          "match": "\\b[0-9][0-9_]*(?:\\.[0-9_]+)?(?:[eE][+-]?[0-9_]+)?(?:[iuf](?:8|16|32|64|128|size))?\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.gossamer",
          "match": "\\b(if|else|match|loop|while|for|in|break|continue|return|yield|defer|select|go)\\b"
        },
        {
          "name": "keyword.other.gossamer",
          "match": "\\b(as|async|await|const|crate|dyn|enum|extern|fn|impl|let|mod|mut|pub|ref|self|Self|static|struct|super|trait|type|unsafe|use|where)\\b"
        },
        {
          "name": "entity.name.function.macro.gossamer",
          "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*!"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "support.type.primitive.gossamer",
          "match": "\\b(bool|char|str|i8|i16|i32|i64|i128|isize|u8|u16|u32|u64|u128|usize|f32|f64)\\b"
        },
        {
          "name": "support.type.gossamer",
          "match": "\\b(Arc|Array|BTreeMap|BTreeSet|Box|HashMap|HashSet|Mutex|Option|Receiver|Result|Sender|String|Vec)\\b"
        },
        {
          "name": "entity.name.type.gossamer",
          "match": "\\b[A-Z][A-Za-z0-9_]*\\b"
        }
      ]
    },
    "literals": {
      "patterns": [
        {
          "name": "constant.language.gossamer",
          "match": "\\b(true|false|None|Some|Ok|Err)\\b"
        }
      ]
    },
    "pipe": {
      "patterns": [
        {
          "name": "keyword.operator.pipe.gossamer",
          "match": "\\|>"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.gossamer",
          "match": "(==|!=|<=|>=|&&|\\|\\||<<|>>|\\+=|-=|\\*=|/=|%=|&=|\\|=|\\^=|->|=>|\\.\\.=|\\.\\.|::)"
        },
        {
          "name": "keyword.operator.gossamer",
          "match": "[+\\-*/%<>!~|&^?.=]"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "entity.name.function.gossamer",
          "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*(?=\\s*\\()"
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "name": "variable.other.gossamer",
          "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
        }
      ]
    }
  }
}
