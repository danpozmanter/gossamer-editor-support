{
  "name": "tree-sitter-gossamer",
  "version": "0.1.0",
  "description": "Tree-sitter grammar for the Gossamer programming language.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/gossamer-lang/gossamer-site.git"
  },
  "main": "bindings/node",
  "keywords": [
    "parser",
    "tree-sitter",
    "gossamer"
  ],
  "scripts": {
    "build": "tree-sitter generate && tree-sitter build",
    "test": "tree-sitter test"
  },
  "dependencies": {
    "node-addon-api": "^7.1.0",
    "node-gyp-build": "^4.8.0"
  },
  "devDependencies": {
    "tree-sitter-cli": "^0.22.0"
  },
  "tree-sitter": [
    {
      "scope": "source.gossamer",
      "file-types": [
        "gos"
      ],
      "highlights": "queries/highlights.scm",
      "injection-regex": "^gossamer$"
    }
  ]
}
